{
  "name": "claude2gemini-cli",
  "version": "0.1.0",
  "description": "Claude API compatible proxy backed by Gemini CLI SDK",
  "type": "module",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "account:add": "tsx cli/manage-accounts.ts add",
    "account:list": "tsx cli/manage-accounts.ts list",
    "account:remove": "tsx cli/manage-accounts.ts remove",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/gemini-cli-sdk": "file:./gemini-cli/packages/sdk",
    "express": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
